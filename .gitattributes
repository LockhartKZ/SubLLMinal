# Normalize line endings: store text as LF in the repo, check out native on Windows.
* text=auto

# Always LF for these (scripts/config that tooling may be picky about)
*.ts   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.rs   text eol=lf
*.md   text eol=lf
*.srt  text eol=lf
*.ass  text eol=lf

# PowerShell scripts use CRLF
*.ps1  text eol=crlf

# Binary assets — never normalize
*.png  binary
*.ico  binary
*.icns binary
